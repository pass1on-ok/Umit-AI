generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// prisma/schema.prisma

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  role Role @default(PATIENT)
  profile   Profile?
  hadsResponses HadsResponse[]
  symptoms Symptom[]
}

model Profile {
  id             Int      @id @default(autoincrement())
  gender         String?
  dateOfBirth    DateTime?
  address        String?
  userId         Int      @unique 
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HadsResponse{
  id              Int      @id @default(autoincrement())
  createdAt       DateTime     @default(now())
  
  answers         Int[]    

  anxietyScore    Int
  depressionScore Int
  

  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Symptom {
  id          Int            @id @default(autoincrement())
  createdAt   DateTime       @default(now())
  description String?        @db.Text
  
  userId      Int
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  values      SymptomValue[] 
}

model SymptomValue {
  id       Int    @id @default(autoincrement())
  type     String 
  severity Int

  entryId  Int
  entry    Symptom @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

enum Role {
  PATIENT
  DOCTOR
  PSYCHOLOGIST
  ADMIN
}

